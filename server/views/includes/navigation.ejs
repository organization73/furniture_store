<div class="backdrop"></div>
<header class="main-header">
  <button id="side-menu-toggle">Menu</button>
  <nav class="main-header__nav">
    <ul class="main-header__item-list">
      <% if (isAuthenticated) { %>

      <li class="main-header__item">
        <a class="<%= path === '/' ? 'active' : '' %>" href="/admin/">Home</a>
      </li>
      <li class="main-header__item">
        <a cclass="<%= path === '/chat' ? 'active' : '' %>" href="/admin/chat"
          >Chat</a
        >
      </li>
      <li class="main-header__item"></li>
      <li class="main-header__item">
        <a
          class="<%= path === '/products' ? 'active' : '' %>"
          href="/gallory/products"
          >Admin Products
        </a>
      </li>
      <% } %>
    </ul>
    <ul class="main-header__item-list">
      <% if (!isAuthenticated) { %>
      <li class="main-header__item">
        <a class="<%= path === '/login' ? 'active' : '' %>" href="/admin/login"
          >Login</a
        >
      </li>
      <li class="main-header__item">
        <a
          class="<%= path === '/signup' ? 'active' : '' %>"
          href="/admin/signup"
          >Signup</a
        >
      </li>
      <% } else { %>
      <li class="main-header__item">
        <a class="<%= path === '/profile' ? 'active' : '' %>" href="/profile"
          >Profile</a
        >
      </li>

      <li class="main-header__item">
        <form action="/admin/logout" method="post">
          <button type="submit">Logout</button>
        </form>
      </li>
      <% } %>
    </ul>
  </nav>
</header>

<nav class="mobile-nav">
  <ul class="mobile-nav__item-list">
    <% if (isAuthenticated) { %>
    <li class="mobile-nav__item">
      <a class="<%= path === '/' ? 'active' : '' %>" href="/admin/">Home</a>
    </li>
    <li class="mobile-nav__item">
      <a class="<%= path === '/chat' ? 'active' : '' %>" href="/admin/chat"
        >Chat</a
      >
    </li>

    <% } %> <% if (!isAuthenticated) { %>
    <li class="mobile-nav__item">
      <a class="<%= path === '/login' ? 'active' : '' %>" href="/admin/login"
        >Login</a
      >
    </li>
    <li class="mobile-nav__item">
      <a class="<%= path === '/signup' ? 'active' : '' %>" href="/admin/signup"
        >Signup</a
      >
    </li>
    <% } else { %>
    <li class="mobile-nav__item">
      <form action="/admin/logout" method="post">
        <button type="submit">Logout</button>
      </form>
    </li>
    <% } %>
  </ul>
</nav>
