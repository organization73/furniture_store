<%- include('../includes/head.ejs') %>
  <link rel="stylesheet" href="/css/forms.css">
  <link rel="stylesheet" href="/css/auth.css">
  </head>

  <body>
    <%- include('../includes/navigation.ejs') %>

      <main>
        <% if (errorMessage) { %>
          <div class="user-message user-message--error">
            <%= errorMessage %>
          </div>
          <% } %>
            <form class="login-form" action="/admin/signup" method="POST" enctype="application/json">
              <div class="form-control">
                <label for="firstName">first name</label>
                <input class="<%=validationErrors.find(e=>e.path === 'firstName')? 'invalid':'' %>" type="firstName"
                  name="firstName" value="<%= oldInput.firstName %>" id="firstName">
              </div>
              <div class="form-control">
                <label for="lastName">last name</label>
                <input class="<%=validationErrors.find(e=>e.path === 'lastName')? 'invalid':'' %>" type="lastName"
                  name="lastName" value="<%= oldInput.lastName %>" id="lastName">
              </div>
              <div class="form-control">
                <label for="username">User name</label>
                <input class="<%=validationErrors.find(e=>e.path === 'username')? 'invalid':'' %>" type="username"
                  name="username" value="<%= oldInput.username %>" id="username">
              </div>
              <div class="form-control">
                <label for="email">E-Mail</label>
                <input class="<%=validationErrors.find(e=>e.path === 'email')? 'invalid':'' %>" type="email"
                  name="email" value="<%= oldInput.email %>" id="email">
              </div>
              <div class="form-control">
                <label for="password">Password</label>
                <input class="<%=validationErrors.find(e=>e.path === 'password')? 'invalid':'' %>" type="password"
                  name="password" id="password">
              </div>
              <div class="form-control">
                <label for="confirmPassword">Confirm Password</label>
                <input class="<%=validationErrors.find(e=>e.path === 'confirmPassword')? 'invalid':'' %>"
                  type="password" name="confirmPassword" id="confirmPassword">
              </div>
              <button class="btn" type="submit">Signup</button>
            </form>
      </main>
      <%- include('../includes/end.ejs') %>