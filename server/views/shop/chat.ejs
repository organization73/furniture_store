<%- include('../includes/head.ejs') %>
<style>
    body {
      font-family: sans-serif;
      margin: 0;
      padding: 0;
    }

    #contact-list {
      width: 200px;
      height: 100vh;
      float: left;
      border-right: 1px solid black;
      display: flex;
      flex-direction: column;
    }

    #contact-list h2 {
      margin: 0;
      padding: 10px;
      background-color: #eee;
    }

    #contact-list input[type="text"] {
      margin: 10px;
      padding: 5px;
    }

    #contact-list button {
      margin: 10px;
      padding: 5px;
      background-color: #4caf50;
      color: white;
      border: none;
    }

    #contact-list ul {
      list-style: none;
      margin: 0;
      padding: 0;
      overflow-y: scroll;
      flex: 1;
    }

    #contact-list li {
      padding: 10px;
      background-color: #f5f5f5;
      cursor: pointer;
    }

    #contact-list li.selected {
      background-color: #ddd;
    }

    #chat-room {
      margin-left: 200px;
      padding: 20px;
      display: flex;
      flex-direction: column;
    }

    #chat-room h2 {
      margin: 0;
      padding: 10px;
      background-color: #eee;
    }

    #messages {
      height: 400px;
      overflow-y: scroll;
      border: 1px solid #ddd;
      padding: 10px;
      margin-bottom: 10px;
    }

    #message-input {
      margin-bottom: 10px;
    }

    button {
      padding: 5px;
      background-color: #4caf50;
      color: white;
      border: none;
    }
    #contact-dropdown {
  height: 30px;
  margin: 10px;
  padding: 5px;
  border: 1px solid #ddd;
  border-radius: 4px;
  }
  </style>
</head>

